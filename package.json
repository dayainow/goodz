{
  "name": "goodz",
  "version": "0.1.0",
  "private": true,
  "description": "기획부터 배포까지 연결하는 Goodz 풀 프로세스 운영 시스템",
  "repository": {
    "type": "git",
    "url": "https://github.com/dayainow/goodz.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "check:workspace": "manypkg check",
    "check:deps": "node scripts/check-phantom-deps.mjs",
    "check:process": "node scripts/validate-process.mjs",
    "check:template": "node scripts/validate-template.mjs",
    "check:sqlite": "pnpm --filter @goodz/api-server check:sqlite",
    "sync:github-trace": "node scripts/sync-github-trace.mjs",
    "sync:github-trace:check": "node scripts/sync-github-trace.mjs --check",
    "snapshot:metrics": "node scripts/snapshot-metrics.mjs",
    "snapshot:metrics:check": "node scripts/snapshot-metrics.mjs --check",
    "smoke:staging": "node scripts/smoke-staging.mjs",
    "smoke:process-os": "node scripts/smoke-process-os.mjs",
    "verify": "pnpm check:workspace && pnpm check:deps && pnpm check:process && pnpm check:template && pnpm check:sqlite && turbo build && turbo lint"
  },
  "devDependencies": {
    "@manypkg/cli": "^0.25.1",
    "depcheck": "^1.4.7",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.13"
  }
}
