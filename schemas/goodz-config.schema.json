{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goodz.systems/schemas/goodz-config.schema.json",
  "title": "Goodz Platform Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "product", "platform", "references", "portability"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "edition", "description"],
      "properties": {
        "name": { "const": "Goodz" },
        "edition": { "enum": ["core", "cloud", "enterprise"] },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelPackage", "consoleApp", "apiPrefix", "sourceOfTruth"],
      "properties": {
        "modelPackage": { "const": "@goodz/process" },
        "consoleApp": { "type": "string", "minLength": 1 },
        "apiPrefix": { "const": "/api/process" },
        "sourceOfTruth": { "type": "string", "minLength": 1 }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "domain", "typePackage", "apps", "apiPrefix"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "typePackage": { "type": "string", "minLength": 1 },
          "apps": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "apiPrefix": { "type": "string", "minLength": 1 }
        }
      }
    },
    "portability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coreChangesAllowedForNewReference", "coreContract", "requiredCommands"],
      "properties": {
        "coreChangesAllowedForNewReference": { "const": false },
        "coreContract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "path", "sha256"],
          "properties": {
            "version": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "requiredCommands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
