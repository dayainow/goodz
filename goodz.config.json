{
  "$schema": "./schemas/goodz-config.schema.json",
  "version": 2,
  "product": {
    "name": "Goodz",
    "edition": "core",
    "description": "기획부터 배포까지 연결하는 풀 프로세스 운영 시스템"
  },
  "platform": {
    "modelPackage": "@goodz/process",
    "consoleApp": "apps/process-dashboard",
    "apiPrefix": "/api/process",
    "sourceOfTruth": "operations-db",
    "internalReference": {
      "id": "goodz-development",
      "name": "Goodz Product Development",
      "statusPath": "references/goodz-internal/status.json",
      "metricsPath": "references/goodz-internal/metrics-snapshots.json"
    }
  },
  "references": [
    {
      "id": "goodz-commerce",
      "name": "Goodz Commerce Reference",
      "domain": "commerce",
      "typePackage": "@goodz/types",
      "apps": [
        "apps/web-shop",
        "apps/admin-dashboard"
      ],
      "apiPrefix": "/api"
    },
    {
      "id": "internal-service",
      "name": "Goodz Internal Service Reference",
      "domain": "internal-platform",
      "typePackage": "@goodz/internal-service-types",
      "apps": [
        "references/internal-service/apps/api"
      ],
      "apiPrefix": "/api/services"
    }
  ],
  "portability": {
    "coreChangesAllowedForNewReference": false,
    "coreContract": {
      "version": "1.1.0",
      "path": "packages/process/src/index.ts",
      "sha256": "9c70d1d1c04dd02ab485b55ff1523644da01e3b4a1be71329bb0040f55d9fe48"
    },
    "requiredCommands": [
      "pnpm check:template",
      "pnpm check:portability",
      "pnpm verify"
    ]
  },
  "delivery": {
    "exportRoot": "docs/projects",
    "manifestRoot": ".goodz/exports",
    "git": {
      "remote": "origin",
      "base": "main",
      "branchPrefix": "goodz/"
    }
  }
}
