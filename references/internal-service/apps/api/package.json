{
  "name": "@goodz/internal-service-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Goodz non-commerce portability reference API",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsx src/validate.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@goodz/internal-service-types": "workspace:*"
  },
  "devDependencies": {
    "@goodz/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
